{
  "name": "tellodb-platform-qwik",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --mode ssr",
    "build.client": "node ./node_modules/vite/bin/vite.js build",
    "build.server": "node ./node_modules/vite/bin/vite.js build -c adapters/node-server/vite.config.ts",
    "build": "npm run build.client && npm run build.server",
    "build.vercel": "npm run build.client && node ./node_modules/vite/bin/vite.js build -c adapters/vercel-edge/vite.config.ts && node scripts/generate-sitemap.mjs",
    "serve": "node server/entry.node-server",
    "typecheck": "node ./node_modules/typescript/lib/tsc.js --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@sentry/browser": "^10.55.0",
    "@supabase/supabase-js": "^2.101.1",
    "@types/node": "^25.5.0",
    "@vercel/analytics": "^2.0.1",
    "d3": "^7.9.0",
    "dotenv": "^17.4.1",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "lucide-qwik": "^1.0.0",
    "marked": "^17.0.5",
    "posthog-js": "^1.376.4",
    "stripe": "^16.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/d3": "^7.4.3",
    "autoprefixer": "^10.4.27",
    "flowbite": "^2.5.2",
    "flowbite-qwik": "^1.1.2",
    "flowbite-qwik-icons": "^0.1.10",
    "husky": "^9.1.7",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17"
  }
}
